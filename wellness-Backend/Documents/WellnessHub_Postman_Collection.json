					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Save token\", function() {",
									"  var json = pm.response.json();",
									"  pm.environment.set(\"token\", json.data.token);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"admin@wellnesshub.com\",\n    \"password\": \"Admin@123\"\n}"
						},
						"url": {
